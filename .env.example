PORT=3000
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require
FRONTEND_ORIGIN=http://localhost:5173

# ESP32 HTTP base URL on your LAN — required for /gateway/* (API must reach the ESP32)
# ESP32_GATEWAY_URL=http://192.168.0.42
# ESP32_GATEWAY_TIMEOUT_MS=120000

# Relatório Teams a cada 30 min (gráfico + resumo por paciente)
# TEAMS_REPORT_ENABLED=true
# TEAMS_REPORT_INTERVAL_MINUTES=30
# TEAMS_REPORT_WINDOW_MINUTES=60

# Opção A — Power Automate (recomendado): fluxo HTTP → "Post message in a chat or channel"
# TEAMS_FLOW_WEBHOOK_URL=https://prod-xx.westus.logic.azure.com/workflows/.../triggers/manual/paths/invoke?...

# Opção B — Microsoft Graph API (chat 1:1 pelo e-mail)
# TEAMS_TENANT_ID=
# TEAMS_CLIENT_ID=
# TEAMS_CLIENT_SECRET=
# TEAMS_SENDER_EMAIL=bot@anery.com.br